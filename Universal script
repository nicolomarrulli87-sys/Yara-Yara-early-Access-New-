local toggled = false
local args = { 1 }

AutoNicoButton.MouseButton1Click:Connect(function()
	toggled = not toggled
	if toggled then
		AutoNicoButton.BackgroundColor3 = Color3.fromRGB(255, 75, 75)
		AutoNicoButton.TextColor3 = Color3.fromRGB(255, 255, 255)
		ButtonStroke.Color = Color3.fromRGB(235, 50, 50)
		
		while toggled do
			game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("ClickBrainrot"):FireServer(unpack(args))
			task.wait(0.001)
		end
	else
		AutoNicoButton.BackgroundColor3 = Color3.fromRGB(245, 246, 248)
		AutoNicoButton.TextColor3 = Color3.fromRGB(40, 45, 55)
		ButtonStroke.Color = Color3.fromRGB(220, 225, 235)
	end
end)
